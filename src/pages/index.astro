---
import BaseLayout from '../layouts/BaseLayout.astro';
import SiteHeader from '../components/SiteHeader.astro';
import Hero from '../components/Hero.astro';
import Galerie from '../components/Galerie.astro';
import WorumEsGeht from '../components/WorumEsGeht.astro';
import BevorStadtratEntscheidet from '../components/BevorStadtratEntscheidet.astro';
import Argumente from '../components/Argumente.astro';
import Forderungen from '../components/Forderungen.astro';
// News-Sektion vorerst ausgeblendet — wird später wieder aktiviert
// import News from '../components/News.astro';
import Stimmen from '../components/Stimmen.astro';
import Verantwortliche from '../components/Verantwortliche.astro';
import Mitmachen from '../components/Mitmachen.astro';
import Termine from '../components/Termine.astro';
import Materialien from '../components/Materialien.astro';
import Kontakt from '../components/Kontakt.astro';
import SiteFooter from '../components/SiteFooter.astro';
import StickyMobileCTA from '../components/StickyMobileCTA.astro';
---

<BaseLayout>
  <SiteHeader />
  <main>
    <Hero />
    <Galerie />
    <WorumEsGeht />
    <BevorStadtratEntscheidet />
    <Stimmen />
    <Argumente />
    <Forderungen />
    <Verantwortliche />
    <Mitmachen />
    <Termine />
    <Materialien />
    <Kontakt />
  </main>
  <SiteFooter />
  <StickyMobileCTA />
</BaseLayout>
