---
import data from '../data/mitmachen.json';

const m = data.mitmachen;
---

<section id="mitmachen" class="bg-[var(--color-text-primary)] text-white py-16 md:py-24">
  <div class="container-page">
    <div class="max-w-3xl mb-10 md:mb-14">
      <p class="text-sm uppercase tracking-wider text-[var(--color-accent)] font-semibold mb-3">
        Aktiv werden
      </p>
      <h2 class="text-white mb-4">{m.ueberschrift}</h2>
      <p class="text-lg text-white/80">{m.untertitel}</p>
    </div>

    <ol class="max-w-4xl divide-y divide-white/10 border-y border-white/15">
      {m.optionen.map((opt, i) => (
        <li class="grid grid-cols-[auto_1fr] md:grid-cols-[140px_1fr_auto] gap-6 md:gap-10 items-start py-8 md:py-10">
          <div class="flex flex-col items-start">
            <span class="font-serif font-bold text-5xl md:text-7xl leading-none" style="color: #c1272d;">
              {String(i + 1).padStart(2, '0')}
            </span>
            <span class="hidden md:inline-block mt-2 text-[11px] uppercase tracking-wider font-semibold text-white/50">
              Schritt {i + 1}
            </span>
          </div>
          <div class="min-w-0 col-span-2 md:col-span-1">
            <h3 class="text-white font-serif font-bold text-xl md:text-2xl mb-2 leading-tight">
              {opt.titel}
            </h3>
            <p class="text-[15px] md:text-base text-white/80 leading-relaxed max-w-2xl">
              {opt.text}
            </p>
          </div>
          <div class="col-span-2 md:col-span-1 md:pt-2">
            <a
              href={opt.cta_href}
              target={opt.cta_href.startsWith('http') ? '_blank' : undefined}
              rel={opt.cta_href.startsWith('http') ? 'noopener' : undefined}
              class="inline-flex items-center gap-2 px-5 py-3 rounded-md font-semibold text-sm md:text-[15px] no-underline transition-colors whitespace-nowrap"
              style="background-color: #c1272d; color: #ffffff; text-decoration: none;"
              onmouseover="this.style.backgroundColor='#9a1f24'"
              onmouseout="this.style.backgroundColor='#c1272d'"
            >
              {opt.cta_label}
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
                <path d="M5 12h14M13 6l6 6-6 6"/>
              </svg>
            </a>
          </div>
        </li>
      ))}
    </ol>
  </div>
</section>
