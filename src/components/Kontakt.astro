---
import meta from '../data/meta.json';
---

<section id="kontakt" class="bg-[var(--color-bg-card)] py-16 md:py-24 border-t border-[var(--color-border)]">
  <div class="container-page">
    <div class="max-w-3xl mb-10">
      <p class="text-sm uppercase tracking-wider text-[var(--color-accent)] font-semibold mb-3">
        Schreiben Sie uns
      </p>
      <h2 class="mb-5">Kontakt</h2>
      <p class="text-lg text-[var(--color-text-body)] leading-relaxed">
        Sie haben Hinweise, möchten die Initiative unterstützen, sind selbst betroffen oder haben eine Presseanfrage? Schreiben Sie uns. Wir antworten in der Regel innerhalb von 48 Stunden.
      </p>
    </div>

    <div class="grid sm:grid-cols-2 gap-5 md:gap-6 max-w-3xl">
      <a
        href={`mailto:${meta.kontakt.email}`}
        class="group block p-7 md:p-8 rounded-md bg-[var(--color-bg)] border border-[var(--color-border)] no-underline hover:border-[var(--color-accent)] transition-colors"
      >
        <div class="flex items-center gap-3 mb-3 text-[var(--color-accent)]">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/>
            <polyline points="22,6 12,13 2,6"/>
          </svg>
          <span class="text-xs uppercase tracking-wider font-semibold text-[var(--color-text-muted)]">
            E-Mail
          </span>
        </div>
        <p class="font-serif font-semibold text-[var(--color-text-primary)] text-lg md:text-xl mb-1 break-all group-hover:text-[var(--color-accent)] transition-colors">
          {meta.kontakt.email}
        </p>
        <p class="text-sm text-[var(--color-text-muted)]">
          Direkter Kontakt zur Initiative — Hinweise, Unterstützung, Pressefragen
        </p>
      </a>

      <a
        href={meta.kontakt.petition}
        target="_blank"
        rel="noopener"
        class="group block p-7 md:p-8 rounded-md bg-[var(--color-accent)] text-white no-underline hover:bg-[var(--color-accent-dark)] transition-colors"
      >
        <div class="flex items-center gap-3 mb-3 text-white/80">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
          </svg>
          <span class="text-xs uppercase tracking-wider font-semibold text-white/80">
            Petition
          </span>
        </div>
        <p class="font-serif font-semibold text-white text-lg md:text-xl mb-1">
          Petition unterzeichnen
        </p>
        <p class="text-sm text-white/85">
          openpetition.de — gerichtet an den Koblenzer Stadtrat
        </p>
      </a>
    </div>

    <p class="mt-8 text-sm text-[var(--color-text-muted)] max-w-3xl">
      Verantwortlich nach § 18 Abs. 2 MStV: Dirk Schmid, Pestalozzistr. 26, 56073 Koblenz. Vollständige Angaben siehe <a href="/impressum">Impressum</a>.
    </p>
  </div>
</section>
