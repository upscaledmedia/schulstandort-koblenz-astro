---
import meta from '../data/meta.json';
---

<section id="kontakt" class="bg-[var(--color-bg-card)] py-16 md:py-24 border-t border-[var(--color-border)]">
  <div class="container-page">
    <div class="max-w-3xl mb-10">
      <p class="text-sm uppercase tracking-wider text-[var(--color-accent)] font-semibold mb-3">
        Persönliche Anfragen
      </p>
      <h2 class="mb-5">Kontakt</h2>
      <p class="text-lg text-[var(--color-text-body)] leading-relaxed">
        Persönliche Anfragen bitte über die openPetition-Kommentarfunktion — siehe Mitmachen-Sektion. Dort werden alle Beiträge öffentlich dokumentiert und vom Stadtrat zur Kenntnis genommen.
      </p>
    </div>

    <div class="grid md:grid-cols-2 gap-5 md:gap-6">
      <a
        href={meta.kontakt.petition_kommentare}
        target="_blank"
        rel="noopener"
        class="group block p-8 md:p-10 rounded-md bg-[var(--color-bg)] border border-[var(--color-border)] no-underline hover:border-[var(--color-accent)] transition-colors"
      >
        <div class="flex items-center gap-3 mb-4 text-[var(--color-accent)]">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/>
          </svg>
          <span class="text-xs uppercase tracking-wider font-semibold text-[var(--color-text-muted)]">
            Kommentar
          </span>
        </div>
        <p class="font-serif font-semibold text-[var(--color-text-primary)] text-xl md:text-2xl mb-2 group-hover:text-[var(--color-accent)] transition-colors">
          Kommentar auf openPetition
        </p>
        <p class="text-sm md:text-base text-[var(--color-text-muted)]">
          Hinweise und Meinungen öffentlich dokumentiert — der Stadtrat liest mit
        </p>
      </a>

      <a
        href={meta.kontakt.petition}
        target="_blank"
        rel="noopener"
        class="group block p-8 md:p-10 rounded-md bg-[var(--color-accent)] text-white no-underline hover:bg-[var(--color-accent-dark)] transition-colors"
      >
        <div class="flex items-center gap-3 mb-4 text-white/80">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
          </svg>
          <span class="text-xs uppercase tracking-wider font-semibold text-white/80">
            Petition
          </span>
        </div>
        <p class="font-serif font-semibold text-white text-xl md:text-2xl mb-2">
          Petition unterzeichnen
        </p>
        <p class="text-sm md:text-base text-white/85">
          openpetition.de — gerichtet an den Koblenzer Stadtrat
        </p>
      </a>
    </div>
  </div>
</section>
