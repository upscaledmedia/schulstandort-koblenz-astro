---
import data from '../data/forderungen.json';
const f = data.forderungen;
---

<section id="forderungen" class="bg-[var(--color-bg-card)] py-16 md:py-24">
  <div class="container-page">
    <div class="max-w-3xl mb-10 md:mb-12">
      <p class="text-sm uppercase tracking-wider text-[var(--color-accent)] font-semibold mb-3">
        Was wir konkret fordern
      </p>
      <h2 class="mb-5">{f.ueberschrift}</h2>
      <p class="text-lg text-[var(--color-text-muted)]">{f.untertitel}</p>
    </div>

    <div class="grid md:grid-cols-2 gap-4 md:gap-5">
      {f.liste.map((forderung) => (
        <div class="flex gap-4 md:gap-5 p-6 rounded-md bg-[var(--color-bg)] border border-[var(--color-border)]">
          <span class="flex-none font-serif font-bold text-3xl md:text-4xl text-[var(--color-accent)] leading-none">
            {String(forderung.nummer).padStart(2, '0')}
          </span>
          <div class="flex-1 min-w-0">
            <h3 class="font-serif font-bold text-[var(--color-text-primary)] text-lg mb-2">
              {forderung.titel}
            </h3>
            <p class="text-[15px] text-[var(--color-text-body)] leading-relaxed">
              {forderung.text}
            </p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
