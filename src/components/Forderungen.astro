---
import data from '../data/forderungen.json';
const f = data.forderungen;
---

<section id="forderungen" class="bg-[var(--color-bg-card)] py-16 md:py-24">
  <div class="container-page">
    <div class="max-w-3xl mb-10 md:mb-12">
      <p class="text-sm uppercase tracking-wider text-[var(--color-accent)] font-semibold mb-3">
        Was wir konkret fordern
      </p>
      <h2 class="mb-5">{f.ueberschrift}</h2>
      {f.lead && (
        <p class="font-serif font-bold text-xl md:text-2xl text-[var(--color-text-primary)] leading-snug mb-4">
          {f.lead}
        </p>
      )}
      <p class="text-lg text-[var(--color-text-muted)]">{f.untertitel}</p>
    </div>

    <div class="grid md:grid-cols-2 gap-4 md:gap-5">
      {f.liste.map((forderung) => {
        const renderText = () => {
          if (forderung.highlight && forderung.text.includes(forderung.highlight)) {
            const parts = forderung.text.split(forderung.highlight);
            return (
              <p class="text-[15px] text-[var(--color-text-body)] leading-relaxed">
                {parts[0]}
                <strong class="font-semibold text-[var(--color-text-primary)]">{forderung.highlight}</strong>
                {parts[1]}
              </p>
            );
          }
          return (
            <p class="text-[15px] text-[var(--color-text-body)] leading-relaxed">
              {forderung.text}
            </p>
          );
        };
        return (
          <div class="flex gap-4 md:gap-5 p-6 rounded-md bg-[var(--color-bg)] border border-[var(--color-border)]">
            <span class="flex-none font-serif font-bold text-3xl md:text-4xl text-[var(--color-accent)] leading-none">
              {String(forderung.nummer).padStart(2, '0')}
            </span>
            <div class="flex-1 min-w-0">
              <h3 class="font-serif font-bold text-[var(--color-text-primary)] text-lg mb-2">
                {forderung.titel}
              </h3>
              {renderText()}
            </div>
          </div>
        );
      })}
    </div>

    <div class="mt-12 md:mt-16 max-w-4xl p-8 md:p-10 rounded-md" style="background-color: #c1272d;">
      <h3 class="text-white font-serif font-semibold text-2xl md:text-3xl leading-tight mb-3">
        Diese Forderungen brauchen Druck — von dir.
      </h3>
      <p class="text-white/90 text-[15px] md:text-base leading-relaxed mb-6 md:mb-7 max-w-2xl">
        Wenn du diese Forderungen unterstützt, hilf öffentlich Druck aufzubauen: Petition unterzeichnen und einen persönlichen Kommentar hinterlassen — beides zählt für den Stadtrat.
      </p>
      <div class="flex flex-col sm:flex-row gap-3 sm:gap-4">
        <a
          href="https://www.openpetition.de/petition/online/keine-interimsschule-in-der-goldgrube-auf-kosten-unserer-kinder"
          target="_blank"
          rel="noopener"
          class="cta-on-red cta-primary"
        >
          Petition unterzeichnen
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
            <path d="M5 12h14M13 6l6 6-6 6"/>
          </svg>
        </a>
        <a
          href="https://www.openpetition.de/petition/kommentare/keine-interimsschule-in-der-goldgrube-auf-kosten-unserer-kinder"
          target="_blank"
          rel="noopener"
          class="cta-on-red cta-secondary"
        >
          Meinung als Kommentar teilen
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
            <path d="M5 12h14M13 6l6 6-6 6"/>
          </svg>
        </a>
      </div>
    </div>
  </div>
</section>
