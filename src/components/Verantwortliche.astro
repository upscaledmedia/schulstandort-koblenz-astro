---
import data from '../data/verantwortliche.json';
const v = data.verantwortliche;

// Stadtratsmitglieder nach Fraktion gruppieren — Reihenfolge wie in fraktionen_im_stadtrat
const fraktionsReihenfolge = v.fraktionen_im_stadtrat.map((f) => f.name);
const mitgliederNachFraktion = fraktionsReihenfolge.map((fraktionName) => ({
  name: fraktionName,
  mitglieder: (v.stadtratsmitglieder || [])
    .filter((m) => m.fraktion === fraktionName)
    .sort((a, b) => a.name.localeCompare(b.name, 'de')),
}));
const stadtratGesamt = (v.stadtratsmitglieder || []).length;
---

<section id="verantwortliche" class="bg-[var(--color-bg)] py-16 md:py-24">
  <div class="container-page">
    <div class="max-w-3xl mb-10 md:mb-12">
      <p class="text-sm uppercase tracking-wider text-[var(--color-accent)] font-semibold mb-3">
        Wer entscheidet
      </p>
      <h2 class="mb-4">{v.ueberschrift}</h2>
      <p class="text-lg text-[var(--color-text-muted)] mb-4">{v.untertitel}</p>
      <p class="text-sm text-[var(--color-text-muted)] italic">{v.hinweis}</p>
    </div>

    <div class="mb-12">
      <h3 class="text-xl font-serif font-bold mb-5 text-[var(--color-text-primary)]">
        Verfahrensverantwortliche
      </h3>
      <div class="grid md:grid-cols-3 gap-5">
        {v.verfahrensverantwortliche.map((person) => (
          <div class="bg-[var(--color-bg-card)] border border-[var(--color-border)] p-6 rounded-md">
            <p class="text-xs uppercase tracking-wider text-[var(--color-accent)] font-semibold mb-1">
              {person.rolle}
            </p>
            <p class="font-serif font-bold text-[var(--color-text-primary)] text-lg mb-1">
              {person.profil_url ? (
                <a
                  href={person.profil_url}
                  target="_blank"
                  rel="noopener"
                  class="no-underline hover:text-[var(--color-accent)] transition-colors"
                >
                  {person.name}
                </a>
              ) : (
                person.name
              )}
            </p>
            {person.partei && (
              <p class="text-sm text-[var(--color-text-muted)] mb-3">{person.partei}</p>
            )}
            <p class="text-[14px] text-[var(--color-text-body)] leading-relaxed mb-3">
              {person.position_oeffentlich}
            </p>
            <p class="text-xs text-[var(--color-text-muted)] italic">
              Quelle: {person.quelle}
            </p>
          </div>
        ))}
      </div>
    </div>

    {v.befuerworter && v.befuerworter.length > 0 && (
      <div class="mb-12">
        <h3 class="text-xl font-serif font-bold mb-2 text-[var(--color-text-primary)]">
          Bekannte Befürworter im Stadtrat
        </h3>
        <p class="text-sm text-[var(--color-text-muted)] mb-5">
          Folgende Stadtratsmitglieder haben sich öffentlich für den Standort Goldgrube ausgesprochen.
        </p>
        <div class="grid md:grid-cols-2 gap-5 max-w-4xl">
          {v.befuerworter.map((person) => (
            <div
              class="bg-[var(--color-bg-card)] p-6 rounded-md border border-[var(--color-border)] border-l-4"
              style="border-left-color: #c89b3c;"
            >
              <p class="text-xs uppercase tracking-wider font-semibold mb-1" style="color: #c89b3c;">
                {person.rolle}
              </p>
              <p class="font-serif font-bold text-[var(--color-text-primary)] text-lg mb-1">
                {person.profil_url ? (
                  <a
                    href={person.profil_url}
                    target="_blank"
                    rel="noopener"
                    class="no-underline hover:text-[var(--color-accent)] transition-colors"
                  >
                    {person.name}
                  </a>
                ) : (
                  person.name
                )}
              </p>
              {person.partei && (
                <p class="text-sm text-[var(--color-text-muted)] mb-3">{person.partei}</p>
              )}
              <p class="text-[14px] text-[var(--color-text-body)] leading-relaxed mb-3">
                {person.position_oeffentlich}
              </p>
              <p class="text-xs text-[var(--color-text-muted)] italic">
                Quelle: {person.quelle}
              </p>
            </div>
          ))}
        </div>
      </div>
    )}

    <div>
      <div class="flex items-end justify-between flex-wrap gap-3 mb-5">
        <h3 class="text-xl font-serif font-bold text-[var(--color-text-primary)]">
          Fraktionen im Stadtrat
        </h3>
        <p class="text-sm text-[var(--color-text-muted)]">
          {v.fraktionen_im_stadtrat.reduce((sum, f) => sum + f.sitze, 0)} Sitze · Mehrheit: {v.mehrheit_erforderlich}
        </p>
      </div>
      <div class="bg-[var(--color-bg-card)] border border-[var(--color-border)] rounded-md overflow-hidden">
        <table class="w-full text-sm">
          <thead class="bg-[var(--color-bg)]">
            <tr class="border-b border-[var(--color-border)]">
              <th class="text-left p-4 font-semibold text-[var(--color-text-primary)] uppercase text-xs tracking-wider">Fraktion</th>
              <th class="text-right p-4 font-semibold text-[var(--color-text-primary)] uppercase text-xs tracking-wider w-24">Sitze</th>
              <th class="text-left p-4 font-semibold text-[var(--color-text-primary)] uppercase text-xs tracking-wider hidden md:table-cell">Position</th>
            </tr>
          </thead>
          <tbody>
            {v.fraktionen_im_stadtrat.map((f) => (
              <tr class="border-b border-[var(--color-border)] last:border-0">
                <td class="p-4 font-medium text-[var(--color-text-primary)]">{f.name}</td>
                <td class="p-4 text-right font-mono">{f.sitze}</td>
                <td class="p-4 text-[var(--color-text-body)] hidden md:table-cell">{f.position}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </div>

    {v.stadtratsmitglieder && v.stadtratsmitglieder.length > 0 && (
      <div class="mt-12 md:mt-16">
        <div class="max-w-3xl mb-8">
          <h3 class="text-xl md:text-2xl font-serif font-bold mb-3 text-[var(--color-text-primary)]">
            {stadtratGesamt === 56 ? 'Alle 56 Stadtratsmitglieder' : `Bekannte Stadtratsmitglieder (${stadtratGesamt})`}
          </h3>
          <p class="text-[var(--color-text-muted)] text-base md:text-lg">
            Diese Personen entscheiden am 28. Mai 2026 über die Beschlussvorlage BV/0197/2026.
            Bürgerinnen und Bürger sind eingeladen, sich direkt an ihre Vertreterinnen
            und Vertreter zu wenden — sachlich, höflich und mit Bezug zum Standort Goldgrube.
          </p>
        </div>

        <div class="space-y-8">
          {mitgliederNachFraktion.map((fraktion) => (
            fraktion.mitglieder.length > 0 && (
              <div>
                <div class="flex items-baseline justify-between mb-3 pb-2 border-b border-[var(--color-border)]">
                  <h4 class="text-base font-semibold text-[var(--color-text-primary)] uppercase tracking-wider">
                    {fraktion.name}
                  </h4>
                  <span class="text-xs text-[var(--color-text-muted)] font-mono">
                    {fraktion.mitglieder.length} {fraktion.mitglieder.length === 1 ? 'Mitglied' : 'Mitglieder'}
                  </span>
                </div>
                <ul class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-x-6 gap-y-2">
                  {fraktion.mitglieder.map((person) => (
                    <li class="text-[14px] text-[var(--color-text-body)] leading-snug py-1">
                      {person.profil_url ? (
                        <a
                          href={person.profil_url}
                          target="_blank"
                          rel="noopener"
                          class="font-medium text-[var(--color-text-primary)] hover:text-[var(--color-accent)] transition-colors no-underline"
                        >
                          {person.name}
                        </a>
                      ) : (
                        <span class="font-medium text-[var(--color-text-primary)]">{person.name}</span>
                      )}
                      {person.funktion && (
                        <span class="block text-xs text-[var(--color-text-muted)] mt-0.5">
                          {person.funktion}
                        </span>
                      )}
                    </li>
                  ))}
                </ul>
              </div>
            )
          ))}
        </div>

        {v.stadtratsmitglieder_quelle && (
          <p class="text-xs text-[var(--color-text-muted)] mt-6 italic">
            Quelle: {v.stadtratsmitglieder_quelle}
          </p>
        )}
      </div>
    )}
  </div>
</section>
