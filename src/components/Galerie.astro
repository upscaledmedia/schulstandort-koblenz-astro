---
const bilder = [
  {
    src: '/images/plan-schule.jpg',
    alt: 'Planungsdokument: Lageplan der geplanten Schulanlage in der Goldgrube',
    caption: 'Lageplan'
  },
  {
    src: '/images/baustelle.webp',
    alt: 'Baustelle der bestehenden Pestalozzi-Grundschule in der Goldgrube',
    caption: 'Bestand: Pestalozzi-Schule'
  },
  {
    src: '/images/verkehr-koblenz-goldgrube.webp',
    alt: 'Aktuelle Verkehrssituation in der Goldgrube',
    caption: 'Verkehr Goldgrube'
  }
];
---

<section class="bg-[var(--color-bg)] py-12 md:py-16" aria-label="Bildergalerie zur Goldgrube">
  <div class="container-page">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-4 md:gap-6">
      {bilder.map((bild) => (
        <figure class="m-0">
          <div class="aspect-[4/3] overflow-hidden rounded-md bg-[var(--color-bg-deep)]/10">
            <img
              src={bild.src}
              alt={bild.alt}
              loading="lazy"
              decoding="async"
              class="w-full h-full object-cover"
            />
          </div>
          <figcaption class="text-xs text-[var(--color-text-muted)] mt-2 leading-snug">
            {bild.caption}
          </figcaption>
        </figure>
      ))}
    </div>
  </div>
</section>
