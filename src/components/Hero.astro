---
import hero from '../data/hero.json';
import Countdown from './Countdown.astro';

const h = hero.hero;
---

<section class="relative overflow-hidden bg-[var(--color-bg-deep)] text-white">
  <img
    src="/images/pestalozzi-grundschule-koblenz.webp"
    alt=""
    aria-hidden="true"
    loading="eager"
    decoding="async"
    class="absolute inset-0 w-full h-full object-cover"
    style="opacity: 0.55;"
  />
  <div
    class="absolute inset-0"
    style="background: linear-gradient(180deg, rgba(17,25,42,0.55) 0%, rgba(17,25,42,0.68) 70%, rgba(17,25,42,0.82) 100%);"
    aria-hidden="true"
  ></div>
  <div
    class="absolute inset-x-0 top-0 h-px"
    style="background: linear-gradient(90deg, transparent 0%, rgba(255,255,255,0.18) 50%, transparent 100%);"
    aria-hidden="true"
  ></div>
  <div
    class="absolute inset-x-0 bottom-0 h-px"
    style="background: linear-gradient(90deg, transparent 0%, rgba(255,255,255,0.12) 50%, transparent 100%);"
    aria-hidden="true"
  ></div>

  <div class="relative container-page py-16 md:py-24 lg:py-28" id="hauptinhalt">
    <div class="grid lg:grid-cols-12 gap-10 lg:gap-12 items-start">
      <div class="lg:col-span-7">
        <p class="inline-flex items-center gap-2 text-sm md:text-base text-white/90 uppercase tracking-wider font-medium mb-4" style="text-shadow: 0 1px 4px rgba(0,0,0,0.5);">
          <span class="w-8 h-px bg-[var(--color-accent)]" aria-hidden="true"></span>
          {h.kicker}
        </p>
        <h1 class="text-white !text-balance mb-6" style="text-shadow: 0 2px 12px rgba(0,0,0,0.65);">
          {h.headline}
        </h1>
        <p class="text-lg md:text-xl text-white/95 leading-relaxed mb-10 md:mb-12" style="text-shadow: 0 1px 6px rgba(0,0,0,0.55);">
          {h.subheadline}
        </p>

        <div class="lg:hidden mb-10">
          <div
            class="rounded-xl bg-[#ffffff] text-[var(--color-text-body)] p-5 sm:p-6"
            style="box-shadow: 0 20px 45px -20px rgba(0,0,0,0.55);"
          >
            <p class="text-xs uppercase tracking-wider text-[var(--color-accent)] font-semibold mb-2">
              Direkt hier unterzeichnen
            </p>
            <h2 class="text-xl font-bold mb-4 leading-snug">Petition jetzt unterstützen</h2>
            <div class="op-widget-container" style="width: 100%; max-width: 500px; margin: 0 auto;">
              <script
                is:inline
                type="text/javascript"
                src="https://www.openpetition.de/widget/petition/keine-interimsschule-in-der-goldgrube-auf-kosten-unserer-kinder"
              ></script>
            </div>
            <p class="text-center text-[11px] text-[var(--color-text-muted)] mt-3 leading-snug">
              Widget bereitgestellt von openPetition.de — Klick auf „Jetzt unterzeichnen" öffnet die Petition.
            </p>
          </div>
          <Countdown />
        </div>
      </div>

      <aside class="hidden lg:block lg:col-span-5">
        <div
          class="rounded-xl bg-[#ffffff] text-[var(--color-text-body)] p-6 xl:p-7"
          style="box-shadow: 0 25px 60px -25px rgba(0,0,0,0.6);"
        >
          <p class="text-xs uppercase tracking-wider text-[var(--color-accent)] font-semibold mb-2">
            Direkt hier unterzeichnen
          </p>
          <h2 class="text-xl xl:text-2xl font-bold mb-4 leading-snug">Petition jetzt unterstützen</h2>
          <div class="op-widget-container" style="width: 100%; max-width: 500px; margin: 0 auto;">
            <script
              is:inline
              type="text/javascript"
              src="https://www.openpetition.de/widget/petition/keine-interimsschule-in-der-goldgrube-auf-kosten-unserer-kinder"
            ></script>
          </div>
          <p class="text-center text-[11px] text-[var(--color-text-muted)] mt-3 leading-snug">
            Widget bereitgestellt von openPetition.de — Klick auf „Jetzt unterzeichnen" öffnet die Petition.
          </p>
        </div>
        <Countdown />
      </aside>
    </div>
  </div>

  <div class="relative bg-white/5 backdrop-blur-sm border-t border-white/10">
    <div class="container-page py-6 md:py-8">
      <div class="grid grid-cols-2 lg:grid-cols-4 gap-6 md:gap-8">
        {h.facts_strip.map((fact, i) => (
          <div class={`${i > 0 ? 'lg:border-l border-white/15 lg:pl-8' : ''}`}>
            <div class="font-serif text-2xl md:text-3xl font-bold text-white mb-1">
              {fact.value}
            </div>
            <div class="text-xs md:text-sm text-white/70 leading-snug">
              {fact.label}
            </div>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>
