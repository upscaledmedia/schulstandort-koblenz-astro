---
import hero from '../data/hero.json';
import meta from '../data/meta.json';
import Countdown from './Countdown.astro';

const h = hero.hero;
---

<section class="relative overflow-hidden bg-[var(--color-bg-deep)] text-white">
  <img
    src="/images/pestalozzi-grundschule-koblenz.webp"
    alt=""
    aria-hidden="true"
    loading="eager"
    decoding="async"
    class="absolute inset-0 w-full h-full object-cover"
    style="opacity: 0.55;"
  />
  <div
    class="absolute inset-0"
    style="background: linear-gradient(180deg, rgba(17,25,42,0.55) 0%, rgba(17,25,42,0.68) 70%, rgba(17,25,42,0.82) 100%);"
    aria-hidden="true"
  ></div>
  <div
    class="absolute inset-x-0 top-0 h-px"
    style="background: linear-gradient(90deg, transparent 0%, rgba(255,255,255,0.18) 50%, transparent 100%);"
    aria-hidden="true"
  ></div>
  <div
    class="absolute inset-x-0 bottom-0 h-px"
    style="background: linear-gradient(90deg, transparent 0%, rgba(255,255,255,0.12) 50%, transparent 100%);"
    aria-hidden="true"
  ></div>

  <div class="relative container-page py-16 md:py-24 lg:py-28" id="hauptinhalt">
    <div class="grid lg:grid-cols-12 gap-10 lg:gap-12 items-start">
      <div class="lg:col-span-7">
        <p class="inline-flex items-center gap-2 text-sm md:text-base text-white/90 uppercase tracking-wider font-medium mb-4" style="text-shadow: 0 1px 4px rgba(0,0,0,0.5);">
          <span class="w-8 h-px bg-[var(--color-accent)]" aria-hidden="true"></span>
          {h.kicker}
        </p>
        <h1 class="text-white !text-balance mb-6" style="text-shadow: 0 2px 12px rgba(0,0,0,0.65);">
          {h.headline}
        </h1>
        <p class="text-lg md:text-xl text-white/95 leading-relaxed mb-6 md:mb-8" style="text-shadow: 0 1px 6px rgba(0,0,0,0.55);">
          {h.subheadline}
        </p>

        <div class="flex flex-col sm:flex-row sm:flex-wrap gap-3 mb-8 md:mb-10">
          <a
            href={hero.hero.cta_primary?.href ?? 'https://www.openpetition.de/petition/online/keine-interimsschule-in-der-goldgrube-auf-kosten-unserer-kinder'}
            target="_blank"
            rel="noopener"
            class="inline-flex items-center justify-center gap-2 bg-[#c1272d] hover:bg-[#9a1f24] font-semibold text-[15px] py-3 px-5 rounded-md no-underline transition-colors shadow-md"
            style="color: #ffffff;"
          >
            Petition unterzeichnen
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
              <path d="M5 12h14M13 6l6 6-6 6"/>
            </svg>
          </a>
          <a
            href={meta.kontakt.facebook}
            target="_blank"
            rel="noopener"
            class="inline-flex items-center justify-center gap-2 bg-[#1877F2] hover:bg-[#0c63d4] font-semibold text-[15px] py-3 px-5 rounded-md no-underline transition-colors shadow-md"
            style="color: #ffffff;"
            aria-label="Auf Facebook folgen"
          >
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M22 12c0-5.523-4.477-10-10-10S2 6.477 2 12c0 4.991 3.657 9.128 8.438 9.878v-6.987h-2.54V12h2.54V9.797c0-2.506 1.492-3.89 3.777-3.89 1.094 0 2.238.195 2.238.195v2.46h-1.26c-1.243 0-1.63.771-1.63 1.562V12h2.773l-.443 2.89h-2.33v6.988C18.343 21.128 22 16.991 22 12z"/>
            </svg>
            Auf Facebook folgen
          </a>
          <a
            href={meta.kontakt.instagram}
            target="_blank"
            rel="noopener"
            class="inline-flex items-center justify-center gap-2 bg-gradient-to-tr from-[#feda75] via-[#d62976] to-[#4f5bd5] hover:opacity-90 font-semibold text-[15px] py-3 px-5 rounded-md no-underline transition-opacity shadow-md"
            style="color: #ffffff;"
            aria-label="Auf Instagram folgen"
          >
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <rect x="2" y="2" width="20" height="20" rx="5" ry="5"/>
              <path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/>
              <line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/>
            </svg>
            Auf Instagram folgen
          </a>
        </div>

        <div class="lg:hidden mb-10">
          <div
            class="rounded-xl bg-[#ffffff] text-[var(--color-text-body)] p-5 sm:p-6"
            style="box-shadow: 0 20px 45px -20px rgba(0,0,0,0.55);"
          >
            <p class="text-xs uppercase tracking-wider text-[var(--color-accent)] font-semibold mb-2">
              Direkt hier unterzeichnen
            </p>
            <h2 class="text-xl font-bold mb-4 leading-snug">Petition jetzt unterstützen</h2>
            <div class="op-widget-container" style="width: 100%; max-width: 500px; margin: 0 auto;">
              <script
                is:inline
                type="text/javascript"
                src="https://www.openpetition.de/widget/petition/keine-interimsschule-in-der-goldgrube-auf-kosten-unserer-kinder"
              ></script>
            </div>
            <p class="text-center text-[11px] text-[var(--color-text-muted)] mt-3 leading-snug">
              Widget bereitgestellt von openPetition.de — Klick auf „Jetzt unterzeichnen" öffnet die Petition.
            </p>
          </div>
          <Countdown />
        </div>
      </div>

      <aside class="hidden lg:block lg:col-span-5">
        <div
          class="rounded-xl bg-[#ffffff] text-[var(--color-text-body)] p-6 xl:p-7"
          style="box-shadow: 0 25px 60px -25px rgba(0,0,0,0.6);"
        >
          <p class="text-xs uppercase tracking-wider text-[var(--color-accent)] font-semibold mb-2">
            Direkt hier unterzeichnen
          </p>
          <h2 class="text-xl xl:text-2xl font-bold mb-4 leading-snug">Petition jetzt unterstützen</h2>
          <div class="op-widget-container" style="width: 100%; max-width: 500px; margin: 0 auto;">
            <script
              is:inline
              type="text/javascript"
              src="https://www.openpetition.de/widget/petition/keine-interimsschule-in-der-goldgrube-auf-kosten-unserer-kinder"
            ></script>
          </div>
          <p class="text-center text-[11px] text-[var(--color-text-muted)] mt-3 leading-snug">
            Widget bereitgestellt von openPetition.de — Klick auf „Jetzt unterzeichnen" öffnet die Petition.
          </p>
        </div>
        <Countdown />
      </aside>
    </div>

    <aside
      aria-label="Wichtiger Termin: Bürgerinformation der Stadt am 12. Mai 2026"
      class="relative mt-10 md:mt-14 rounded-xl overflow-hidden"
      style="background: linear-gradient(135deg, rgba(193,39,45,0.32) 0%, rgba(193,39,45,0.14) 60%, rgba(193,39,45,0.08) 100%); border: 1px solid rgba(193,39,45,0.45); border-left: 6px solid #c1272d; box-shadow: 0 14px 40px -18px rgba(0,0,0,0.6);"
    >
      <div class="p-5 md:p-6 lg:p-7">
        <div class="flex items-center gap-3 mb-3">
          <span class="relative flex h-3 w-3" aria-hidden="true">
            <span class="absolute inline-flex h-full w-full rounded-full opacity-70 animate-ping" style="background-color: #ff5860;"></span>
            <span class="relative inline-flex rounded-full h-3 w-3" style="background-color: #ff5860;"></span>
          </span>
          <p class="text-[11px] md:text-xs uppercase tracking-[0.18em] font-bold" style="color: #ffb1b4; text-shadow: 0 1px 4px rgba(0,0,0,0.6);">
            Achtung — Wichtiger Termin · Jede Stimme zählt
          </p>
        </div>

        <div class="grid lg:grid-cols-12 gap-5 lg:gap-8 items-start">

          <div class="lg:col-span-6">
            <h2 class="text-white font-serif font-bold text-2xl md:text-[28px] lg:text-3xl leading-tight mb-3" style="text-shadow: 0 2px 10px rgba(0,0,0,0.6);">
              Wir brauchen dich. Deine Stimme zählt.
            </h2>
            <p class="text-white/95 text-[14px] md:text-[15px] leading-relaxed mb-3" style="text-shadow: 0 1px 6px rgba(0,0,0,0.55);">
              Bürgerinformation in der Pestalozzi-Turnhalle — sechzehn Tage vor der Entscheidung im Stadtrat. <strong class="font-semibold text-white">Eine volle Halle ist ein Signal, das nicht ignoriert werden kann.</strong>
            </p>
            <div class="flex flex-wrap gap-x-5 gap-y-2 text-white text-[14px] md:text-[15px]" style="text-shadow: 0 1px 4px rgba(0,0,0,0.55);">
              <span class="inline-flex items-center gap-1.5">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#ff8a8e" stroke-width="2" aria-hidden="true">
                  <rect x="3" y="4" width="18" height="18" rx="2"/>
                  <line x1="16" y1="2" x2="16" y2="6"/>
                  <line x1="8" y1="2" x2="8" y2="6"/>
                  <line x1="3" y1="10" x2="21" y2="10"/>
                </svg>
                <strong class="font-semibold">Di · 12. Mai · 18:00 Uhr</strong>
              </span>
              <span class="inline-flex items-center gap-1.5">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#ff8a8e" stroke-width="2" aria-hidden="true">
                  <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/>
                  <circle cx="12" cy="10" r="3"/>
                </svg>
                Turnhalle Pestalozzi-Grundschule
              </span>
            </div>
            <p class="text-white/80 text-[13px] mt-2" style="text-shadow: 0 1px 4px rgba(0,0,0,0.55);">
              Anwesend: Prof. Dr. Lukas · Schneider · Lipinski-Naumann + Fachämter
            </p>
          </div>

          <div class="lg:col-span-6">
            <ul class="grid sm:grid-cols-2 gap-x-4 gap-y-1.5 mb-4">
              <li class="flex items-start gap-2 text-white text-[13px] md:text-[14px] leading-snug" style="text-shadow: 0 1px 4px rgba(0,0,0,0.55);">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#ff8a8e" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" class="flex-none mt-1" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
                <span><strong class="font-semibold">Anwesenheit ist das Signal</strong> — auch ohne Frage.</span>
              </li>
              <li class="flex items-start gap-2 text-white text-[13px] md:text-[14px] leading-snug" style="text-shadow: 0 1px 4px rgba(0,0,0,0.55);">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#ff8a8e" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" class="flex-none mt-1" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
                <span><strong class="font-semibold">Jede Stimme zählt</strong> — Stadtrat entscheidet 16 Tage später.</span>
              </li>
              <li class="flex items-start gap-2 text-white text-[13px] md:text-[14px] leading-snug" style="text-shadow: 0 1px 4px rgba(0,0,0,0.55);">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#ff8a8e" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" class="flex-none mt-1" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
                <span><strong class="font-semibold">Bring Nachbarn mit</strong> — Eltern, Großeltern, Freunde.</span>
              </li>
            </ul>

            <div class="flex flex-wrap gap-2">
              <a
                href="/calendar/buergerversammlung-stadt-2026-05-12.ics"
                download
                class="inline-flex items-center justify-center gap-2 bg-[#c1272d] hover:bg-[#9a1f24] font-semibold text-[13px] md:text-[14px] py-2.5 px-4 rounded-md no-underline transition-colors shadow-md"
                style="color: #ffffff;"
              >
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                  <rect x="3" y="4" width="18" height="18" rx="2"/>
                  <line x1="16" y1="2" x2="16" y2="6"/>
                  <line x1="8" y1="2" x2="8" y2="6"/>
                  <line x1="3" y1="10" x2="21" y2="10"/>
                </svg>
                Termin in Kalender
              </a>
              <a
                href={`https://wa.me/?text=${encodeURIComponent('Wichtiger Termin in Koblenz: Bürgerinformation zur Interimsschule Goldgrube am 12. Mai um 18 Uhr in der Turnhalle der Pestalozzi-Grundschule. Bitte kommt zahlreich — eine volle Halle zählt. Mehr Infos: https://schulstandort-koblenz.de/#termine')}`}
                target="_blank"
                rel="noopener"
                class="inline-flex items-center justify-center gap-2 bg-[#25D366] hover:bg-[#1ebd5a] font-semibold text-[13px] md:text-[14px] py-2.5 px-4 rounded-md no-underline transition-colors shadow-md"
                style="color: #ffffff;"
                aria-label="Termin per WhatsApp an Nachbarn weiterleiten"
              >
                <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                  <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 0 0-3.48-8.413Z"/>
                </svg>
                Nachbarn einladen
              </a>
              <a
                href="#termine"
                class="inline-flex items-center justify-center gap-2 bg-white/15 hover:bg-white/25 border border-white/30 font-semibold text-[13px] md:text-[14px] py-2.5 px-4 rounded-md no-underline transition-colors backdrop-blur-sm"
                style="color: #ffffff;"
              >
                Alle Termininfos
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
                  <path d="M5 12h14M13 6l6 6-6 6"/>
                </svg>
              </a>
            </div>
          </div>
        </div>
      </div>
    </aside>
  </div>

  <div class="relative bg-white/5 backdrop-blur-sm border-t border-white/10">
    <div class="container-page py-6 md:py-8">
      <div class="grid grid-cols-2 lg:grid-cols-4 gap-6 md:gap-8">
        {h.facts_strip.map((fact, i) => (
          <div class={`${i > 0 ? 'lg:border-l border-white/15 lg:pl-8' : ''}`}>
            <div class="font-serif text-2xl md:text-3xl font-bold text-white mb-1">
              {fact.value}
            </div>
            <div class="text-xs md:text-sm text-white/70 leading-snug">
              {fact.label}
            </div>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>
