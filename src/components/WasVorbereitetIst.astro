---
import data from '../data/was-vorbereitet-ist.json';
import fs from 'node:fs';
import path from 'node:path';

const w = data.was_vorbereitet_ist;
const bild = w.rechts_spalte.bild;

// Build-time Check: existiert das Bild im public-Ordner?
const publicPath = path.join(process.cwd(), 'public', bild.pfad.replace(/^\//, ''));
const bildVorhanden = fs.existsSync(publicPath);

// Hilfsfunktion: einfache **fett**-Markierung (markdown-style) zu <strong>
function renderBold(text: string): string {
  return text.replace(/\*\*(.+?)\*\*/g, '<strong>$1</strong>');
}
---

<section id="was-vorbereitet-ist" class="bg-[var(--color-bg-card)] py-16 md:py-24 border-y border-[var(--color-border)]">
  <div class="container-page">
    <div class="max-w-3xl mb-10 md:mb-14">
      <p class="text-sm uppercase tracking-wider text-[var(--color-accent)] font-semibold mb-3">
        Vorbereitete Schritte
      </p>
      <h2 class="text-[var(--color-text-primary)] mb-4">{w.ueberschrift}</h2>
      <p class="text-lg md:text-xl text-[var(--color-text-muted)] leading-snug">
        {w.untertitel}
      </p>
    </div>

    <div class="grid md:grid-cols-2 gap-10 md:gap-14 items-start">
      <!-- Linke Spalte: Vorbereitete Schritte -->
      <div class="bg-[var(--color-bg)] rounded-md border border-[var(--color-border)] p-7 md:p-9">
        <h3 class="font-serif font-bold text-xl md:text-2xl text-[var(--color-text-primary)] mb-5 leading-snug border-l-3 border-[var(--color-accent)] pl-4" style="border-left-width: 3px;">
          {w.links_spalte.ueberschrift}
        </h3>
        <div class="space-y-4 md:space-y-5">
          {w.links_spalte.paragraphen.map((p) => (
            <p class="text-[15px] md:text-base text-[var(--color-text-body)] leading-relaxed" set:html={renderBold(p)} />
          ))}
        </div>
      </div>

      <!-- Rechte Spalte: Vergleichsfall + Bild -->
      <div>
        <div class="bg-[#c1272d] text-white rounded-md p-7 md:p-9 mb-6">
          <p class="text-xs uppercase tracking-wider text-white/80 font-semibold mb-3">
            Vergleichsfall
          </p>
          <blockquote class="font-serif font-bold text-[1.375rem] md:text-[1.625rem] leading-tight mb-5">
            „{w.rechts_spalte.ueberschrift}"
          </blockquote>
          <div class="space-y-4 text-white/90 text-[15px] md:text-base leading-relaxed">
            {w.rechts_spalte.paragraphen.map((p) => (
              <p set:html={renderBold(p)} />
            ))}
          </div>
        </div>

        <!-- Bild-Slot -->
        <figure class="m-0">
          {bildVorhanden ? (
            <img
              src={bild.pfad}
              alt={bild.alt}
              loading="lazy"
              class="w-full aspect-[4/3] object-cover rounded-md border border-[var(--color-border)]"
            />
          ) : (
            <div
              class="w-full aspect-[4/3] rounded-md border border-dashed border-[var(--color-border)] bg-[var(--color-bg-card)] grid place-items-center px-6 text-center"
              role="img"
              aria-label={bild.alt}
            >
              <div>
                <svg class="w-10 h-10 mx-auto mb-3 text-[var(--color-text-muted)] opacity-60" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
                  <rect x="3" y="3" width="18" height="18" rx="2" />
                  <circle cx="9" cy="9" r="2" />
                  <path d="m21 15-5-5L5 21" />
                </svg>
                <p class="text-xs md:text-[13px] text-[var(--color-text-muted)] leading-snug max-w-xs mx-auto">
                  {bild.platzhalter_text}
                </p>
              </div>
            </div>
          )}
          <figcaption class="mt-3 text-xs md:text-[13px] text-[var(--color-text-muted)] leading-snug">
            {bild.foto_credit} ·{' '}
            <a
              href={bild.quelle_url}
              target="_blank"
              rel="noopener"
              class="underline underline-offset-2 hover:text-[var(--color-accent)]"
            >
              {bild.quelle_label}
            </a>
          </figcaption>
        </figure>
      </div>
    </div>
  </div>
</section>
