---
const navItems = [
  { label: 'Wieso', href: '#kernbefunde' },
  { label: 'Meinungen', href: '#stimmen' },
  { label: '15 Argumente', href: '#argumente' },
  { label: 'Forderungen', href: '#forderungen' },
  { label: 'Mitmachen', href: '#mitmachen' },
  { label: 'Termine', href: '#termine' },
  { label: 'Quellen', href: '#materialien' },
];

const petitionHref = 'https://www.openpetition.de/petition/online/keine-interimsschule-in-der-goldgrube-auf-kosten-unserer-kinder';
---

<header class="bg-white border-b border-[var(--color-border)] sticky top-0 z-40 backdrop-blur-md bg-white/95">
  <div class="container-page flex items-center justify-between gap-4 py-3 md:py-4">
    <a href="/" class="flex items-center gap-3 no-underline group min-w-0" aria-label="Zur Startseite">
      <img
        src="/logo-header.png"
        alt=""
        aria-hidden="true"
        width="48"
        height="48"
        class="flex-none w-10 h-10 md:w-12 md:h-12 rounded-full"
        loading="eager"
        decoding="async"
      />
      <span class="flex flex-col leading-tight min-w-0">
        <span class="font-serif font-bold text-[var(--color-text-primary)] text-[15px] md:text-[17px] leading-tight">
          Koblenzer Bürger
        </span>
        <span class="font-serif font-normal text-[var(--color-text-muted)] text-[12px] md:text-[13px] leading-tight mt-0.5">
          für nachhaltige Schulplanung
        </span>
      </span>
    </a>
    <nav class="hidden lg:flex items-center gap-6" aria-label="Hauptnavigation">
      {navItems.map((item) => (
        <a
          href={item.href}
          class="text-sm font-medium text-[var(--color-text-primary)] no-underline hover:text-[var(--color-accent)] transition-colors"
        >
          {item.label}
        </a>
      ))}
      <a
        href={petitionHref}
        target="_blank"
        rel="noopener"
        class="inline-flex items-center gap-2 bg-[#c1272d] hover:bg-[#9a1f24] !text-white px-4 py-2 rounded-md font-semibold text-sm no-underline transition-colors"
        style="color: #ffffff;"
      >
        Petition unterzeichnen
        <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
          <path d="M5 12h14M13 6l6 6-6 6"/>
        </svg>
      </a>
    </nav>
    <button
      type="button"
      id="mobile-menu-toggle"
      aria-label="Menü öffnen"
      aria-controls="mobile-menu"
      aria-expanded="false"
      class="lg:hidden p-2 -mr-2 text-[var(--color-text-primary)]"
    >
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <line x1="3" y1="6" x2="21" y2="6" />
        <line x1="3" y1="12" x2="21" y2="12" />
        <line x1="3" y1="18" x2="21" y2="18" />
      </svg>
    </button>
  </div>
  <div id="mobile-menu" class="lg:hidden hidden border-t border-[var(--color-border)] bg-white">
    <nav class="container-page py-3 flex flex-col" aria-label="Mobile Navigation">
      {navItems.map((item) => (
        <a
          href={item.href}
          class="py-3 text-base font-medium text-[var(--color-text-primary)] no-underline border-b border-[var(--color-border)] last:border-0"
          data-nav-link
        >
          {item.label}
        </a>
      ))}
      <a
        href={petitionHref}
        target="_blank"
        rel="noopener"
        class="mt-3 inline-flex items-center justify-center gap-2 bg-[#c1272d] hover:bg-[#9a1f24] !text-white px-4 py-3 rounded-md font-semibold text-base no-underline"
        style="color: #ffffff;"
        data-nav-link
      >
        Petition unterzeichnen
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
          <path d="M5 12h14M13 6l6 6-6 6"/>
        </svg>
      </a>
    </nav>
  </div>
</header>

<script>
  const toggle = document.getElementById('mobile-menu-toggle');
  const menu = document.getElementById('mobile-menu');
  if (toggle && menu) {
    toggle.addEventListener('click', () => {
      const open = menu.classList.toggle('hidden') === false;
      toggle.setAttribute('aria-expanded', String(open));
      toggle.setAttribute('aria-label', open ? 'Menü schließen' : 'Menü öffnen');
    });
    menu.querySelectorAll('[data-nav-link]').forEach((link) => {
      link.addEventListener('click', () => {
        menu.classList.add('hidden');
        toggle.setAttribute('aria-expanded', 'false');
      });
    });
  }
</script>
