---
import meta from '../data/meta.json';
---

<div
  id="sticky-sidebars"
  class="hidden lg:block"
  data-storage-key="goldgrube-sticky-sidebars-dismissed"
  aria-hidden="true"
>
  <aside
    class="sticky-sidebar-widget fixed right-4 top-1/2 z-20 -translate-y-1/2 opacity-0 transition-all duration-500"
    style="transform: translateY(-50%) translateX(20px);"
  >
    <div class="relative flex flex-col items-center gap-2 rounded-2xl bg-white px-3 py-3 shadow-xl ring-1 ring-black/10">
      <button
        type="button"
        class="sticky-sidebar-close absolute -right-2 -top-2 flex h-5 w-5 items-center justify-center rounded-full bg-white text-[#1a2332] shadow ring-1 ring-black/10 transition hover:scale-110"
        aria-label="Widget schließen"
      >
        <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <line x1="18" y1="6" x2="6" y2="18"/>
          <line x1="6" y1="6" x2="18" y2="18"/>
        </svg>
      </button>

      <span class="text-[11px] font-semibold uppercase tracking-wide text-[#1a2332] leading-none">
        Folge uns
      </span>
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#1a2332" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <line x1="12" y1="5" x2="12" y2="19"/>
        <polyline points="5 12 12 19 19 12"/>
      </svg>

      <a
        href={meta.kontakt.facebook}
        target="_blank"
        rel="noopener"
        aria-label="Auf Facebook folgen"
        class="flex h-11 w-11 items-center justify-center rounded-full bg-[#1877F2] text-white no-underline shadow-md transition-transform hover:scale-110 hover:text-white"
      >
        <svg width="22" height="22" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M22 12c0-5.523-4.477-10-10-10S2 6.477 2 12c0 4.991 3.657 9.128 8.438 9.878v-6.987h-2.54V12h2.54V9.797c0-2.506 1.492-3.89 3.777-3.89 1.094 0 2.238.195 2.238.195v2.46h-1.26c-1.243 0-1.63.771-1.63 1.562V12h2.773l-.443 2.89h-2.33v6.988C18.343 21.128 22 16.991 22 12z"/>
        </svg>
      </a>

      <a
        href={meta.kontakt.instagram}
        target="_blank"
        rel="noopener"
        aria-label="Auf Instagram folgen"
        class="flex h-11 w-11 items-center justify-center rounded-full bg-gradient-to-tr from-[#feda75] via-[#d62976] to-[#4f5bd5] text-white no-underline shadow-md transition-transform hover:scale-110 hover:text-white"
      >
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <rect x="2" y="2" width="20" height="20" rx="5" ry="5"/>
          <path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/>
          <line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/>
        </svg>
      </a>
    </div>
  </aside>
</div>

<style>
  .sticky-sidebar-widget.is-visible {
    opacity: 1 !important;
    transform: translateY(-50%) translateX(0) !important;
  }
</style>

<script is:inline>
  (function () {
    var root = document.getElementById('sticky-sidebars');
    if (!root) return;
    var storageKey = root.getAttribute('data-storage-key') || 'sticky-sidebars-dismissed';

    // localStorage-Persistenz: einmal weggeklickt = dauerhaft aus
    try {
      if (localStorage.getItem(storageKey) === '1') {
        root.style.display = 'none';
        return;
      }
    } catch (_) {
      // localStorage nicht verfügbar (z.B. Safari Private) — Widget trotzdem zeigen
    }

    var widgets = root.querySelectorAll('.sticky-sidebar-widget');
    var threshold = 600;
    var revealed = false;

    function reveal() {
      if (revealed) return;
      if (window.scrollY >= threshold) {
        revealed = true;
        root.setAttribute('aria-hidden', 'false');
        widgets.forEach(function (w) {
          w.classList.add('is-visible');
        });
        window.removeEventListener('scroll', onScroll);
      }
    }

    function onScroll() {
      reveal();
    }

    function dismiss() {
      try {
        localStorage.setItem(storageKey, '1');
      } catch (_) {}
      root.style.display = 'none';
    }

    root.querySelectorAll('.sticky-sidebar-close').forEach(function (btn) {
      btn.addEventListener('click', function (event) {
        event.preventDefault();
        event.stopPropagation();
        dismiss();
      });
    });

    window.addEventListener('scroll', onScroll, { passive: true });
    // Initial-Check, falls Seite mit Scroll-Position geladen wird
    reveal();
  })();
</script>
