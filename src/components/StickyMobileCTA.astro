---
import meta from '../data/meta.json';
---

<div
  id="sticky-cta"
  class="md:hidden fixed bottom-0 inset-x-0 z-30 px-3 pb-3 pt-2 bg-gradient-to-t from-[var(--color-bg-deep)] to-transparent"
>
  <div class="flex gap-2 shadow-lg rounded-md overflow-hidden">
    <a
      href={meta.kontakt.petition}
      target="_blank"
      rel="noopener"
      class="flex-1 inline-flex items-center justify-center gap-1.5 bg-[#c1272d] hover:bg-[#9a1f24] font-semibold text-[14px] py-3 px-3 no-underline transition-colors"
      style="color: #ffffff;"
    >
      Petition unterzeichnen
    </a>
    <a
      href={meta.kontakt.facebook}
      target="_blank"
      rel="noopener"
      class="inline-flex items-center justify-center bg-[#1877F2] hover:bg-[#0c63d4] font-semibold text-[14px] py-3 px-3.5 no-underline transition-colors"
      style="color: #ffffff;"
      aria-label="Auf Facebook folgen"
    >
      <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
        <path d="M22 12c0-5.523-4.477-10-10-10S2 6.477 2 12c0 4.991 3.657 9.128 8.438 9.878v-6.987h-2.54V12h2.54V9.797c0-2.506 1.492-3.89 3.777-3.89 1.094 0 2.238.195 2.238.195v2.46h-1.26c-1.243 0-1.63.771-1.63 1.562V12h2.773l-.443 2.89h-2.33v6.988C18.343 21.128 22 16.991 22 12z"/>
      </svg>
    </a>
    <a
      href={meta.kontakt.instagram}
      target="_blank"
      rel="noopener"
      class="inline-flex items-center justify-center bg-gradient-to-tr from-[#feda75] via-[#d62976] to-[#4f5bd5] hover:opacity-90 font-semibold text-[14px] py-3 px-3.5 no-underline transition-opacity"
      style="color: #ffffff;"
      aria-label="Auf Instagram folgen"
    >
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <rect x="2" y="2" width="20" height="20" rx="5" ry="5"/>
        <path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/>
        <line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/>
      </svg>
    </a>
  </div>
</div>
