---
import { getCollection } from 'astro:content';
import termineMeta from '../data/termine.json';

const all = await getCollection('termine');
const now = new Date();
const future = all
  .filter((t) => t.data.dateStart >= now)
  .sort((a, b) => a.data.dateStart.valueOf() - b.data.dateStart.valueOf());
const past = all
  .filter((t) => t.data.dateStart < now)
  .sort((a, b) => b.data.dateStart.valueOf() - a.data.dateStart.valueOf())
  .slice(0, 3);
const display = [...future, ...past];

const formatDate = (d: Date) =>
  d.toLocaleDateString('de-DE', { day: '2-digit', month: '2-digit', year: 'numeric' });
const formatWeekday = (d: Date) =>
  d.toLocaleDateString('de-DE', { weekday: 'long' });

const meta = termineMeta.termine;
---

<section id="termine" class="bg-[#0d1422] text-white py-16 md:py-24">
  <div class="container-page">
    <div class="max-w-3xl mb-10 md:mb-14">
      <p class="text-sm uppercase tracking-wider font-semibold mb-3" style="color: #c1272d;">
        Termine
      </p>
      <h2 class="text-white mb-4">{meta.ueberschrift}</h2>
      <p class="text-lg text-white/80">{meta.untertitel}</p>
    </div>

    <ol class="space-y-5 max-w-5xl">
      {display.map((t) => {
        const isPast = t.data.status === 'erfolgt';
        const isHigh = t.data.importance === 'high';
        const dateStr = formatDate(t.data.dateStart);
        const weekday = formatWeekday(t.data.dateStart);
        const time = t.data.timeStart;
        return (
          <li
            class={`relative grid md:grid-cols-[1fr_auto] gap-6 md:gap-10 items-start p-6 md:p-8 rounded-md border ${
              isHigh
                ? 'border-[#c1272d]'
                : 'border-white/15'
            } ${isPast ? 'opacity-60' : ''}`}
            style={isHigh ? 'background-color: rgba(193,39,45,0.08);' : 'background-color: rgba(255,255,255,0.04);'}
          >
            <div class="min-w-0">
              <div class="flex items-center gap-2 flex-wrap mb-2">
                <span class="text-[11px] uppercase tracking-wider font-semibold text-white/60">
                  {t.data.eventType}
                </span>
                {isPast && (
                  <span class="text-[11px] uppercase tracking-wider font-semibold px-2 py-0.5 rounded-sm bg-white/15 text-white">
                    Erfolgt
                  </span>
                )}
                {!isPast && isHigh && (
                  <span class="text-[11px] uppercase tracking-wider font-semibold px-2 py-0.5 rounded-sm text-white" style="background-color: #c1272d;">
                    Wichtig
                  </span>
                )}
              </div>
              <h3 class="font-serif font-bold text-white text-2xl md:text-3xl leading-tight mb-3">
                {t.data.title}
              </h3>
              <div class="flex flex-wrap items-center gap-x-5 gap-y-1 text-sm text-white/75 mb-3">
                <span class="inline-flex items-center gap-1.5">
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                    <rect x="3" y="4" width="18" height="18" rx="2" />
                    <line x1="16" y1="2" x2="16" y2="6" />
                    <line x1="8" y1="2" x2="8" y2="6" />
                    <line x1="3" y1="10" x2="21" y2="10" />
                  </svg>
                  <span class="capitalize">{weekday}</span>, {dateStr}{time ? ` · ${time} Uhr` : ' · Uhrzeit folgt'}
                </span>
                {t.data.location && (
                  <span class="inline-flex items-start gap-1.5">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true" class="mt-0.5 flex-none">
                      <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/>
                      <circle cx="12" cy="10" r="3"/>
                    </svg>
                    <span>{t.data.location}</span>
                  </span>
                )}
              </div>
              {t.body && t.body.trim().length > 0 && (
                <div class="text-[15px] text-white/85 leading-relaxed max-w-2xl space-y-3">
                  {t.body.trim().split(/\n\n+/).map((para) => (
                    <p set:html={para.replace(/\n/g, '<br />')} />
                  ))}
                </div>
              )}
              {t.data.videoEmbedUrl && (
                <div class="mt-5 max-w-2xl">
                  <div class="relative w-full overflow-hidden rounded-md border border-white/15" style="padding-top: 56.25%;">
                    <iframe
                      src={t.data.videoEmbedUrl}
                      title={t.data.videoTitle ?? 'Video'}
                      class="absolute inset-0 w-full h-full"
                      loading="lazy"
                      allow="accelerometer; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
                      allowfullscreen
                    />
                  </div>
                  {t.data.videoTitle && (
                    <p class="text-[12px] text-white/60 mt-2">{t.data.videoTitle}</p>
                  )}
                </div>
              )}
              {t.data.attachments && t.data.attachments.length > 0 && (
                <div class="mt-4 flex flex-wrap gap-2">
                  {t.data.attachments.map((a) => (
                    <a
                      href={a.url}
                      target="_blank"
                      rel="noopener"
                      class="inline-flex items-center gap-1.5 text-[13px] font-semibold no-underline px-3 py-1.5 rounded-sm border border-white/20 bg-white/5 hover:bg-white/15 transition-colors"
                      style="color: #ffffff;"
                    >
                      <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                        <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z" />
                        <polyline points="14 2 14 8 20 8" />
                      </svg>
                      {a.label}
                    </a>
                  ))}
                </div>
              )}
              {t.data.linkUrl && (
                <a
                  href={t.data.linkUrl}
                  target="_blank"
                  rel="noopener"
                  class="inline-block mt-3 text-sm font-semibold no-underline hover:underline underline-offset-2"
                  style="color: #c1272d;"
                >
                  {t.data.linkLabel ?? 'Mehr Informationen'} →
                </a>
              )}
            </div>
            {!isPast && t.data.icsFile && (
              <div class="md:pt-1">
                <a
                  href={t.data.icsFile}
                  download
                  class="inline-flex items-center gap-2 px-5 py-3 rounded-md font-semibold text-sm md:text-[15px] no-underline transition-colors whitespace-nowrap"
                  style="background-color: #ffffff; color: #0d1422; text-decoration: none;"
                  onmouseover="this.style.backgroundColor='#f1efe9'"
                  onmouseout="this.style.backgroundColor='#ffffff'"
                  aria-label={`Termin ${t.data.title} als ICS-Datei herunterladen`}
                >
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                    <rect x="3" y="4" width="18" height="18" rx="2" />
                    <line x1="16" y1="2" x2="16" y2="6" />
                    <line x1="8" y1="2" x2="8" y2="6" />
                    <line x1="3" y1="10" x2="21" y2="10" />
                  </svg>
                  In Kalender eintragen
                </a>
              </div>
            )}
          </li>
        );
      })}
    </ol>
  </div>
</section>
