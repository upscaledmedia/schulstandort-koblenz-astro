---
import '../styles/global.css';
import meta from '../data/meta.json';

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
  noindex?: boolean;
  pathname?: string;
  standaloneTitle?: boolean;
}

const {
  title,
  description = meta.site.description,
  ogImage = '/images/pestalozzi-grundschule-koblenz.webp',
  noindex = false,
  pathname = Astro.url.pathname,
  standaloneTitle = false,
} = Astro.props;

// Site-Suffix nur anhängen, wenn er nicht schon im Title vorkommt
const siteName = meta.site.name;
const titleContainsSiteName = title
  ? title.toLowerCase().includes(siteName.toLowerCase()) ||
    title.toLowerCase().includes('bürgerinitiative')
  : false;

const fullTitle = title
  ? (standaloneTitle || titleContainsSiteName ? title : `${title} | ${siteName}`)
  : 'Interimsschule Goldgrube Koblenz — Stadtratsentscheidung 28. Mai';

// Meta-Description auf max. 158 Zeichen begrenzen (Wortgrenze, mit "…" abschließen)
function clampDescription(input: string, max = 158): string {
  if (!input) return input;
  const trimmed = input.trim();
  if (trimmed.length <= max) return trimmed;
  const slice = trimmed.slice(0, max - 1);
  const lastSpace = slice.lastIndexOf(' ');
  const cut = lastSpace > 80 ? slice.slice(0, lastSpace) : slice;
  return cut.replace(/[.,;:–—\-\s]+$/u, '') + '…';
}

const metaDescription = clampDescription(description);

// Trailing-Slash erzwingen für Canonicals (Astro build.format = 'directory' rendert mit Slash)
function ensureTrailingSlash(p: string): string {
  if (!p) return '/';
  // Datei-Pfade (z. B. /sitemap.xml) nicht anfassen
  if (/\.[a-z0-9]+$/i.test(p)) return p;
  return p.endsWith('/') ? p : `${p}/`;
}

const canonicalPath = ensureTrailingSlash(pathname);
const siteOrigin = Astro.site ?? new URL('https://schulstandort-koblenz.de');
const canonicalUrl = new URL(canonicalPath, siteOrigin).toString();
const logoUrl = new URL('/favicon.svg', siteOrigin).toString();

const organizationSchema = {
  '@context': 'https://schema.org',
  '@type': 'NGO',
  name: meta.site.name,
  url: `https://${meta.site.domain_primary}/`,
  description: meta.site.description,
  logo: {
    '@type': 'ImageObject',
    url: logoUrl,
  },
  areaServed: {
    '@type': 'City',
    name: 'Koblenz',
    address: { '@type': 'PostalAddress', addressLocality: 'Koblenz', addressCountry: 'DE' },
  },
};

const websiteSchema = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: meta.site.name,
  url: `https://${meta.site.domain_primary}/`,
  inLanguage: 'de-DE',
};
---

<!doctype html>
<html lang="de">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <meta name="generator" content={Astro.generator} />
    <title>{fullTitle}</title>
    <meta name="description" content={metaDescription} />
    <link rel="canonical" href={canonicalUrl} />
    <meta name="robots" content={noindex ? "noindex, nofollow" : "index, follow"} />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />

    <meta property="og:type" content="website" />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={metaDescription} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={new URL(ogImage, siteOrigin).toString()} />
    <meta property="og:locale" content="de_DE" />
    <meta property="og:site_name" content={meta.site.name} />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={metaDescription} />
    <meta name="twitter:image" content={new URL(ogImage, siteOrigin).toString()} />

    <meta name="theme-color" content="#1a2332" />

    <script is:inline type="application/ld+json" set:html={JSON.stringify(organizationSchema)} />
    <script is:inline type="application/ld+json" set:html={JSON.stringify(websiteSchema)} />

    <slot name="head" />
  </head>
  <body>
    <a
      href="#hauptinhalt"
      class="sr-only focus:not-sr-only focus:fixed focus:top-2 focus:left-2 focus:z-50 focus:bg-[var(--color-text-primary)] focus:text-white focus:px-4 focus:py-2 focus:rounded"
    >
      Zum Inhalt springen
    </a>
    <slot />
  </body>
</html>
